{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "urus",
      "camelcase": "Urus",
      "title": "Urus",
      "scope": "source.urus",
      "file-types": [
        "urus"
      ],
      "injection-regex": "^urus$",
      "class-name": "TreeSitterUrus"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "An attempt to write tree-sitter parser for Urus programming language",
    "authors": [
      {
        "name": "Kamal Fasya",
        "email": "kamalfasya01@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/Urus-Foundation/tree-sitter-urus"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}